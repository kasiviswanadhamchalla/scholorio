type Query {
    getMyIssuedBooks: [IssueResponse]
    getMyIssueHistory: [IssueResponse]
    getDueDates: [IssueResponse]
    countLendingByBook(bookId: ID!): Int!
    countLendingByUser(userId: ID!): Int!
    countActiveLending: Int!
    countOverdueLending: Int!
    countReturnedTodayLending: Int!
    getIssuesByBook: [BookIssueCount!]!
    getIssuesByUser(userId: ID!): [IssueResponse!]!
}

type BookIssueCount {
    bookId: ID!
    issueCount: Int!
}

type Mutation {
    issueBook(input: IssueInput!): IssueRecord
    returnBook(input: ReturnInput!): IssueRecord
    renewBook(input: RenewInput!): IssueRecord
    bulkIssueBooks(input: BulkIssueInput!): [IssueRecord]
}

type IssueResponse {
    id: ID
    bookId: ID
    userId: ID
    issueDate: String
    dueDate: String
    returnDate: String
    state: IssueState
    renewalCount: Int
    penaltyAmount: Float
    createdAt: String
    updatedAt: String
}

type IssueRecord {
    id: ID
    bookId: ID
    userId: ID
    issueDate: String
    dueDate: String
    returnDate: String
    state: IssueState
    renewalCount: Int
    penaltyAmount: Float
    createdAt: String
    updatedAt: String
}

interface IssueState {
    type: String
}

type Requested implements IssueState {
    type: String
}

type Issued implements IssueState {
    issueDate: String
    dueDate: String
    type: String
}

type Returned implements IssueState {
    returnDate: String
    penaltyAmount: Float
    type: String
}

type Overdue implements IssueState {
    dueDate: String
    penaltyAmount: Float
    type: String
}

input IssueInput {
    bookId: ID!
    userId: ID!
}

input BulkIssueInput {
    bookIds: [ID!]!
    userId: ID!
}

input RenewInput {
    issueId: ID!
    userId: ID!
}

input ReturnInput {
    issueId: ID!
    userId: ID!
}
